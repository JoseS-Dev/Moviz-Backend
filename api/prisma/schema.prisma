// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Enum para los tipos de salones
enum TypeRoom {
  Sala_2D
  Sala_3D
  Sala_IMAX
}

// Enum para los tipos de asientos
enum TypeSeat {
  Normal
  VIP
}

// Enum para el estado de las funciones
enum StatusShowtime {
  Programada
  En_Curso
  Cancelada
  Finalizada
}

// Enum para los tipos de idioma de las funciones
enum LanguageType {
  Subtitulada
  Doblada
  Original
}

// Enum para el estado de las reservas
enum StatusBooking {
  Pendiente
  Confirmada
  Cancelada
}

// Enum para la tabla de notificaciones
enum TypeNotification {
  Funciones
  Promociones
  Novedades
}

// Enum para los tipos de promociones
enum TypePromotion {
  Descuento
  Monto_fijo
  Dos_por_uno
}

// Enum para los roles del staff
enum roleStaff {
  Administrador
  Cajero
  Personal_de_limpieza
  Proyeccionista
}

// Enum para los tipos de metraje
enum typeFootage {
  Pelicula
  Serie
  Documental
}

// Modelo para la tabla de los usuarios
model users {
  id Int @id @default(autoincrement())
  names String
  last_names String
  email String @unique
  password_hash String
  username String @unique
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  sessions sessions[]
  favoriteMovies favoriteMovies[]
  reviews reviews[]
  userBadges userBadges[]
  notifications notifications[]
  userPromotions userPromotions[]
  bookings bookings[]
  @@map("users")
}

// Modelo para el inicio de sesión de un usuario
model sessions {
  id Int @id @default(autoincrement())
  user_id Int 
  token String? @unique
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  users users @relation(fields: [user_id], references: [id])
  @@map("sessions")
}

// Modelo para la tabla de las peliculas y series
model footage {
  id Int @id @default(autoincrement())
  title_footage String
  description_footage String?
  type_footage typeFootage
  duration Int
  genre_footage String
  rating_footage Float?
  poster_url String?
  backdrop_url String?
  trailer_url String?
  realease_date DateTime?
  language_footage String
  director_footage String
  cast_footage String[]
  is_active Boolean @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  favoriteMovies favoriteMovies[]
  showtimes showtimes[]
  reviews reviews[]
  @@map("footage")
}

/// Modelo para la tabla de las peliculas favoritas de los usuarios
model favoriteMovies {
  id Int @id @default(autoincrement())
  user_id Int
  movie_id Int
  is_favorite Boolean @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  users users @relation(fields: [user_id], references: [id])
  footage footage @relation(fields: [movie_id], references: [id])
  @@map("favorite_movies")
}

// Modelo para la tabla de los salones donde se va a proyectar las peliculas
model rooms {
  id Int @id @default(autoincrement())
  name_room String
  code_room String @unique
  capacity_room Int
  type_room TypeRoom
  last_maintenance DateTime?
  cleaning_duration Int?
  sound_system String?
  projector_type String?
  has_wheelchair_access Boolean @default(false)
  is_active Boolean @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  showtimes showtimes[]
  seats seats[]
  @@map("rooms")
}

// Modelo para los asientos de cada fila de salón y su disponibilidad
model seats {
  id Int @id @default(autoincrement())
  room_id Int
  raw_number Int
  seat_number Int
  type_seat TypeSeat
  is_available Boolean @default(true)
  is_accessible Boolean @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  rooms rooms @relation(fields: [room_id], references: [id])
  reservedSeats reservedSeats[]
  @@map("seats")
}

// Modelo para las funciones de las peliculas en los salones
model showtimes {
  id Int @id @default(autoincrement())
  movie_id Int
  room_id Int
  start_time DateTime
  end_time DateTime
  price_showtime Float
  status_showtime StatusShowtime @default(Programada)
  language_type LanguageType?
  is_pre_release Boolean @default(false)
  available_seats Int @default(0)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  footage footage @relation(fields: [movie_id], references: [id])
  rooms rooms @relation(fields: [room_id], references: [id])
  bookings bookings[]
  @@map("showtimes")
}

// Modelo para la solicitude de reserva de asientos para una función
model bookings {
  id Int @id @default(autoincrement())
  user_id Int
  showtime_id Int
  staff_id Int?
  total_price Float
  reservation_code String @unique @default(uuid())
  payment_method String?
  status_booking StatusBooking @default(Pendiente)
  reason_cancellation String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  users users @relation(fields: [user_id], references: [id])
  showtimes showtimes @relation(fields: [showtime_id], references: [id])
  staff staff? @relation(fields: [staff_id], references: [id])
  reservedSeats reservedSeats[]
  @@map("bookings")
}

// Modelo para los asientos reservados en cada reserva de la función
model reservedSeats {
  id Int @id @default(autoincrement())
  booking_id Int
  seat_id Int
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  bookings bookings @relation(fields: [booking_id], references: [id])
  seats seats @relation(fields: [seat_id], references: [id])
  @@map("reserved_seats")
}

// Modelo para la tabla de reseñas de las peliculas por parte de los usuarios
model reviews {
  id Int @id @default(autoincrement())
  user_id Int
  movie_id Int
  rating_review Float
  comment_review String?
  is_active Boolean @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  users users @relation(fields: [user_id], references: [id])
  footage footage @relation(fields: [movie_id], references: [id])
  @@map("reviews")
}

// Modelo para la tabla de insignias de los usuarios por su actividad en la plataforma
model badges {
  id Int @id @default(autoincrement())
  name_badge String
  description_badge String?
  icon_badge String?
  is_active Boolean @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  userBadges userBadges[]
  @@map("badges")
}

// Modelo para la tabla intermedia entre los usuarios y las insignias para asignar las insignias a los usuarios
model userBadges {
  id Int @id @default(autoincrement())
  user_id Int
  badge_id Int
  assigned_at DateTime @default(now())
  users users @relation(fields: [user_id], references: [id])
  badges badges @relation(fields: [badge_id], references: [id])
  @@map("user_badges")
}

// Modelo para las notificaciones de los usuarios sobre las funciones, promociones y novedades de la plataforma
model notifications {
  id Int @id @default(autoincrement())
  user_id Int
  title_notification String
  message_notification String
  is_read Boolean @default(false)
  type_notification TypeNotification
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  users users @relation(fields: [user_id], references: [id])
  @@map("notifications")
}

// Modelo para las promociones de la plataforma para las funciones, descuentos y eventos especiales
model promotions {
  id Int @id @default(autoincrement())
  code_promotion String @unique
  name_promotion String
  description_promotion String?
  discount_value Float
  type_promotion TypePromotion
  start_date DateTime
  end_date DateTime?
  is_active Boolean @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  userPromotions userPromotions[]
  @@map("promotions")
}

// Modelo para la tabla intermedia entre las promociones y los usuarios
model userPromotions {
  id Int @id @default(autoincrement())
  user_id Int
  promotion_id Int
  is_used Boolean @default(false)
  redeemed_at DateTime?
  assigned_at DateTime @default(now())
  users users @relation(fields: [user_id], references: [id])
  promotions promotions @relation(fields: [promotion_id], references: [id])
  @@map("user_promotions")
}

// Modelo para manejar el staff del cine
model staff {
  id Int @id @default(autoincrement())
  role_staff roleStaff
  name_staff String
  email_staff String @unique
  hired_at DateTime @default(now())
  member_since DateTime @default(now())
  is_active Boolean @default(true)
  mobile_staff String?
  identification_number String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  canceled_bookings bookings[]
  @@map("staff")
}